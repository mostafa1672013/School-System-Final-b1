# ── Server environment template ─────────────────────────────────────────────
# Copy to `.env` and fill in real values. `.env` is gitignored.

# PostgreSQL connection. Pool params are tuned for ~20 concurrent users.
DATABASE_URL=postgresql://user:password@127.0.0.1:5432/schooldb?connection_limit=15&pool_timeout=10

# Redis — server-side cache for hot reads (reports/permissions/config).
# Read-through, short TTL, never the source of truth. App falls back to direct
# DB query if Redis is unavailable.
REDIS_URL=redis://127.0.0.1:6379

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=8h

# Encryption key for National ID (AES-256-GCM). Must be 32 bytes (hex/base64).
NATIONAL_ID_ENCRYPTION_KEY=change-me-32-byte-key

# Server
PORT=4000
NODE_ENV=development

# Comma-separated CORS allowlist
ALLOWED_ORIGINS=http://127.0.0.1:5173

# Structured slow-request logging threshold (ms). Requests slower than this
# emit a single structured JSON line to stdout.
SLOW_REQUEST_MS=1000

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Student {
  id              String    @id @default(uuid())
  nationalId      String    @unique
  name            String
  photoUrl        String?
  stage           String
  grade           String
  track           String    @default("local") // local, international
  academicYear    String    @default("2024-2025")
  className       String?
  guardianName    String
  guardianPhone   String
  address         String?
  birthDate       String?
  enrollmentDate  String?
  status          String    @default("applied") // applied, under_testing, fee_setup, pending_approval, admitted
  hasSiblings     Boolean   @default(false)
  testResult      String?   // pass, fail
  tuitionFees     Float     @default(0)
  tuitionMandatory Boolean   @default(true)
  booksFees       Float     @default(0)
  booksMandatory   Boolean   @default(true)
  uniformFees     Float     @default(0)
  uniformMandatory Boolean   @default(true)
  busFees         Float     @default(0)
  otherFees       Float     @default(0)
  totalFees       Float     @default(0)
  paidAmount      Float     @default(0)
  pendingPaymentAmount Float?
  pendingPaymentType   String?
  pendingPaymentMethod String?
  pendingWalletPhoneNumber String?
  pendingInstallmentPlanId String?
  pendingInstallmentId String?
  paymentRequestStatus String?
  discountAmount     Float    @default(0)
  discountPercentage Float    @default(0)
  discountApprovedBy String?
  discountStatus     String   @default("approved") // "approved", "pending", "rejected"
  requestedDiscountAmount Float @default(0)
  requestedDiscountPercentage Float @default(0)
  discountRequesterId String?
  discountApproverId  String?
  busRouteId      String?
  documents       Json?     // stores URLs for birth certificate, ID, etc.
  extraFields     Json?     // stores custom fields as { label: string, value: string }[]
  additionalFees  Json?     // [{ name: string, amount: number, isMandatory: boolean }]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  payments        Payment[]
  yearlyFinance   StudentYearlyFinance[]
}

model StageFee {
  id              String   @id @default(uuid())
  stage           String
  grade           String
  track           String   @default("local") // local, international
  academicYear    String
  tuitionFees     Float
  tuitionMandatory Boolean   @default(true)
  booksFees       Float
  booksMandatory   Boolean   @default(true)
  uniformFees     Float
  uniformMandatory Boolean   @default(true)
  applicationFees Float
  applicationMandatory Boolean @default(true)
  additionalFees  Json?     // [{ name: string, amount: number, isMandatory: boolean }]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([stage, grade, track, academicYear])
}

model Payment {
  id            String   @id @default(uuid())
  studentId     String
  studentName   String
  amount        Float
  type          String
  method        String
  date          String
  receiptNumber String   @unique
  collectedBy   String
  academicYear  String?
  notes         String?
  walletPhoneNumber String?
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
}

model StudentYearlyFinance {
  id              String   @id @default(uuid())
  studentId       String
  academicYear    String
  grade           String
  stage           String
  tuitionFees     Float    @default(0)
  booksFees       Float    @default(0)
  uniformFees     Float    @default(0)
  busFees         Float    @default(0)
  otherFees       Float    @default(0)
  totalFees       Float    @default(0)
  paidAmount      Float    @default(0)
  student         Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  @@unique([studentId, academicYear])
}

model InventoryItem {
  id           String   @id @default(uuid())
  name         String
  category     String
  quantity     Int      @default(0)
  minQuantity  Int      @default(5)
  unit         String   @default("قطعة")
  unitPrice    Float    @default(0)
  grade        String?
  description  String?
  lastUpdated  String
}

model BusRoute {
  id           String   @id @default(uuid())
  name         String
  driverName   String
  driverPhone  String
  busNumber    String
  capacity     Int
  monthlyFee   Float
  annualFee    Float
  stops        String[] @default([])
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      String
  avatar    String?
  active    Boolean  @default(true)
  discountLimitPercent Float @default(0)
  createdAt DateTime @default(now())
}

model RoleLimit {
  role          String   @id
  maxPercentage Float
  maxAmount     Float
}
